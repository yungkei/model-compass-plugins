          "version": "1.0.0",
          "author": {
            "name": "Model Compass Team",
            "email": "dev@modelcompass.ai"
          },
          "repository": "https://github.com/yungkei/model-compass-plugins/tree/main/packages/latency-router",
          "npm": "@yungkei/model-compass-latency-router",
          "license": "MIT",
          "tags": ["router", "latency", "performance"],
          "priority": 90
        }
      ]
    }
  ],
